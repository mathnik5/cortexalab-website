---
import { site, placeholders } from '../data/site';
import { links } from '../data/links';
---
<footer class="footer on-ink">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="brand" aria-label={`${site.wordmark} home`}>
        <span class="brand__glyph" aria-hidden="true"></span>
        <span class="brand__word">{site.wordmark}</span>
      </a>
      <p class="footer__tag">{site.wordmark} — {site.tagline}</p>
    </div>

    <nav class="footer__cols" aria-label="Footer">
      <div class="footer__col">
        <h3 class="footer__h">Products</h3>
        <a href="/products">{site.appName}</a>
        <a href="/products">Habit app <span class="soon">(Coming soon)</span></a>
      </div>
      <div class="footer__col">
        <h3 class="footer__h">Company</h3>
        <a href="/about">How we build</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
      <div class="footer__col">
        <h3 class="footer__h">{site.appName}</h3>
        <a href={links.planneat.site} target="_blank" rel="noopener noreferrer">planneat.in</a>
        <a href={links.planneat.googlePlay} target="_blank" rel="noopener noreferrer" data-store="google_play" data-placement="footer">Google Play</a>
        <a href={links.planneat.appStore} target="_blank" rel="noopener noreferrer" data-store="app_store" data-placement="footer">App Store</a>
      </div>
    </nav>
  </div>

  <div class="container footer__legal">
    <span>© {placeholders.founded.value} {site.legalName}. All rights reserved.</span>
    <span class="footer__office">{placeholders.address.value}</span>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--sp-16) var(--sp-8);
    border-top: 1px solid var(--c-border-onink);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--sp-12);
    padding-bottom: var(--sp-12);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--c-text-onink);
    font-family: var(--ff-display);
    font-weight: 700;
    font-size: 1.15rem;
  }
  .brand:hover { color: var(--c-text-onink); }
  .brand__glyph {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--grad-cortex);
  }
  .footer__tag {
    margin-top: var(--sp-3);
    color: var(--c-text-onink-muted);
    font-size: var(--fs-small);
    max-width: 30ch;
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer__h {
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-text-onink-muted);
    margin-bottom: 0.25rem;
  }
  .footer__col a {
    color: var(--c-text-onink);
    font-size: var(--fs-small);
  }
  .footer__col a:hover { color: var(--c-accent-300); }
  .soon { color: var(--c-text-onink-muted); }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--sp-2);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--c-border-onink);
    color: var(--c-text-onink-muted);
    font-size: var(--fs-small);
  }

  @media (max-width: 820px) {
    .footer__inner { grid-template-columns: 1fr; gap: var(--sp-8); }
    .footer__cols { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer__cols { grid-template-columns: 1fr; }
  }
</style>
