---
interface Props {
  tone?: 'live' | 'soon' | 'neutral';
  class?: string;
}
const { tone = 'neutral', class: cls = '' } = Astro.props;
---
<span class={`badge badge--${tone} ${cls}`}>
  {tone === 'live' && <span class="dot" aria-hidden="true"></span>}
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--ff-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    border-radius: var(--r-pill);
    border: 1px solid var(--c-border);
    color: var(--c-text-muted);
    background: var(--c-surface);
  }
  .badge--live {
    color: var(--c-success);
    border-color: rgba(63, 185, 132, 0.3);
    background: rgba(63, 185, 132, 0.08);
  }
  .badge--soon {
    color: var(--c-text-muted);
    border-color: var(--c-border-strong);
    background: rgba(14, 19, 32, 0.03);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-success);
    box-shadow: 0 0 0 0 rgba(63, 185, 132, 0.5);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(63, 185, 132, 0.5); }
    70% { box-shadow: 0 0 0 8px rgba(63, 185, 132, 0); }
    100% { box-shadow: 0 0 0 0 rgba(63, 185, 132, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
  }
</style>
