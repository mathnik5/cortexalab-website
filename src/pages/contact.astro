---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompanyFacts from '../components/CompanyFacts.astro';
import Icon from '../components/Icon.astro';

import { site, placeholders } from '../data/site';
import { links } from '../data/links';

const title = `Get in touch | ${site.wordmark}`;
const description =
  'Questions, partnership ideas, press, or support: reach CortexaLab and you will hear back from the founder directly.';

const methods = [
  {
    icon: 'mail',
    label: 'General enquiries',
    value: placeholders.email.value,
    href: `mailto:${placeholders.email.value}`,
    isPlaceholder: placeholders.email.isPlaceholder,
  },
  {
    icon: 'sparkles',
    label: 'PlanNEat support',
    value: links.planneat.supportEmail,
    href: `mailto:${links.planneat.supportEmail}`,
    isPlaceholder: false,
  },
  {
    icon: 'phone',
    label: 'Phone',
    value: placeholders.phone.value,
    href: undefined,
    isPlaceholder: placeholders.phone.isPlaceholder,
  },
];
---
<BaseLayout title={title} description={description}>
  <section class="section chead">
    <div class="container" data-reveal>
      <p class="eyebrow">Contact</p>
      <h1 class="chead__h">Get in touch</h1>
      <p class="lead">
        Questions, partnership ideas, press, or support: reach out and you'll hear
        back from the founder directly.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="methods" data-reveal-stagger>
        {methods.map((m) => (
          <div class="method">
            <span class="method__icon"><Icon name={m.icon} size={20} /></span>
            <span class="method__label">{m.label}</span>
            {m.href ? (
              <a class="method__value" href={m.href}>{m.value}</a>
            ) : (
              <span class={`method__value ${m.isPlaceholder ? 'tbc' : ''}`}>{m.value}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="h2 facts__h" data-reveal>Company details</h2>
      <CompanyFacts />
    </div>
  </section>
</BaseLayout>

<style>
  .chead__h { margin: var(--sp-3) 0 var(--sp-4); font-size: var(--fs-hero); }

  .methods { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-6); }
  .method {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: var(--sp-6);
    border: 1px solid var(--c-border);
    border-radius: var(--r-card);
    background: var(--c-surface);
  }
  .method__icon {
    display: inline-flex; padding: 0.6rem; width: max-content;
    border-radius: 12px; background: rgba(109, 94, 246, 0.1); color: var(--c-accent);
  }
  .method__label {
    font-family: var(--ff-mono); font-size: 0.72rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--c-text-muted);
  }
  .method__value { font-weight: 500; word-break: break-word; }
  .tbc { color: var(--c-text-muted); font-weight: 400; }
  .facts__h { margin-bottom: var(--sp-8); }

  @media (max-width: 820px) { .methods { grid-template-columns: 1fr; } }
</style>
